{
  "name": "@arkestrator/server",
  "version": "0.1.86",
  "private": true,
  "type": "module",
  "scripts": {
    "ensure-bun": "node scripts/ensure-bun.mjs",
    "predev": "node scripts/ensure-bun.mjs && bun scripts/kill-port.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test src/__tests__ ../packages/protocol/src/__tests__",
    "test:watch": "bun test --watch src/__tests__ ../packages/protocol/src/__tests__",
    "prestart": "node scripts/ensure-bun.mjs && pnpm install",
    "start": "bun src/index.ts",
    "clean": "node -e \"const fs=require('fs');['dist','data'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}})\"",
    "reset:state": "bun scripts/reset-state.ts",
    "build:sidecar": "node scripts/build-sidecar.mjs"
  },
  "dependencies": {
    "@arkestrator/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fflate": "^0.8.2",
    "hono": "^4.12.5",
    "minimatch": "^10.2.4",
    "otpauth": "^9.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "bun-types": "^1.3.10"
  }
}
