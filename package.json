{
  "name": "arkestrator",
  "version": "0.1.52",
  "private": true,
  "scripts": {
    "dev": "pnpm install && pnpm --filter @arkestrator/protocol build && concurrently -n server,client -c blue,green \"pnpm --filter @arkestrator/server dev\" \"pnpm --filter @arkestrator/client tauri dev\"",
    "server": "pnpm --filter @arkestrator/server dev",
    "client": "pnpm --filter @arkestrator/client tauri dev",
    "comfyui:mac": "bash scripts/start-comfyui-bridge-mac.sh",
    "reset:dev": "pnpm --filter @arkestrator/server reset:state",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "setup": "pnpm install && pnpm --filter @arkestrator/protocol build",
    "build:sidecar": "pnpm --filter @arkestrator/protocol build && pnpm --filter @arkestrator/server build:sidecar",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "^1.19.10",
      "express-rate-limit": "^8.2.2"
    },
    "onlyBuiltDependencies": [
      "@tauri-apps/cli",
      "b",
      "d",
      "e",
      "esbuild",
      "i",
      "l",
      "s",
      "u"
    ]
  }
}
