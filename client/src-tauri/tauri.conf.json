{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Arkestrator",
  "mainBinaryName": "arkestrator",
  "version": "0.1.114",
  "identifier": "com.arkestrator.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Arkestrator",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http: https: ws: wss: tauri:; frame-src 'self' http: https:; child-src 'self' http: https:; img-src 'self' data: blob: http: https:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/arkestrator-server"
    ],
    "resources": [
      "../resources/admin-dist"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI5QURERDNFOEYzODIyRjkKUldUNUlqaVBQdDJ0S1lGa0ZWanBvMW1PSHVLRXhCaDF4MEJoWTROOWVSZy9lYUNURG9QNmVNMHQK",
      "endpoints": [
        "https://github.com/timvanhelsdingen/arkestrator/releases/latest/download/latest.json"
      ]
    }
  }
}
